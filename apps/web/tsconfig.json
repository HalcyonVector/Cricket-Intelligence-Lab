{
  "compilerOptions": {
    "target": "ES2020", "lib": ["dom", "esnext"], "jsx": "preserve",
    "module": "esnext", "moduleResolution": "bundler", "strict": true,
    "esModuleInterop": true, "skipLibCheck": true, "noEmit": true,
    "paths": { "@/*": ["./*"] }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
